# MementoOS MVP — Umgebungsvariablen
# OHNE gesetzte URL läuft die App im MOCK-Modus (In-Memory-Beispieldaten,
# kein Netzwerk, kein Konto nötig) — ideal für lokale Entwicklung/Demo.

# Supabase (Projekt in der Region EU — Frankfurt anlegen)
# NEXT_PUBLIC_SUPABASE_URL=https://<projekt>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Nur serverseitig (niemals ins Frontend!) — für Server-Funktionen/Seed
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
